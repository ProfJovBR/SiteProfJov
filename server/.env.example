# Resend API key usada pelo backend para enviar emails
RESEND_API_KEY=re_123456789

# Email que vai receber as mensagens do formulário
CONTACT_TO_EMAIL=jinxtatsuo@gmail.com

# Email remetente configurado no Resend
# Exemplo: Portfolio <onboarding@resend.dev> para testes
# Em produção, use um domínio verificado no Resend
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# URL do frontend permitida no CORS para ambiente local
FRONTEND_URL=http://localhost:5173

# Porta do backend
PORT=3001
